    "api_design": {
      "type": "REST",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/items",
          "description": "获取列表"
        },
        {
          "method": "POST",
          "path": "/api/items",
          "description": "创建项"
        },
        {
          "method": "GET",
          "path": "/api/items/:id",
          "description": "获取详情"
        },
        {
          "method": "PUT",
          "path": "/api/items/:id",
          "description": "更新项"
        },
        {
          "method": "DELETE",
          "path": "/api/items/:id",
          "description": "删除项"
        }
      ]
    }
